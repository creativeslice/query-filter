{
	"name": "query-filter",
	"private": true,
	"description": "Filter blocks for query loops",
	"scripts": {
		"build": "wp-scripts build --experimental-modules --webpack-copy-php",
		"start": "wp-scripts start --experimental-modules",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style --fix",
		"lint:js": "wp-scripts lint-js",
		"plugin-zip": "wp-scripts plugin-zip",
		"release": "npm run build && npm run plugin-zip && mv query-filter.zip \"query-filter-$(sed -n 's/^ \\* Version:[[:space:]]*//p' query-filter.php).zip\"",
		"packages-update": "wp-scripts packages-update"
	},
	"author": "Human Made Limited",
	"license": "GPL-2.0-or-later",
	"dependencies": {
		"@wordpress/scripts": "^33.0.0"
	}
}
